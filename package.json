{
  "name": "grabbr",
  "version": "v0.2.1",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "electrobun": "v1.18.4-beta.6",
      "@typescript/native-preview": "latest"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check:types": "turbo check:types",
    "dev:web": "turbo -F web dev",
    "dev:ui": "turbo -F ui dev",
    "dev:desktop": "turbo -F desktop dev",
    "build:web": "turbo -F web build",
    "build:ui": "turbo -F ui build",
    "build:desktop": "turbo -F desktop build",
    "build:desktop:stable": "turbo -F desktop build:stable",
    "build:desktop:canary": "turbo -F desktop build:canary",
    "check": "oxlint && oxfmt --write",
    "clean": "bun run scripts/clean.ts",
    "in": "bun i && bun update --recursive && bun update --recursive -i",
    "scripts:bin": "turbo -F desktop scripts:bin"
  },
  "devDependencies": {
    "@grabbr/config": "workspace:*",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260617.2",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "turbo": "^2.9.18"
  },
  "packageManager": "bun@1.3.14"
}
