{
  "name": "grabbr",
  "version": "0.1.6",
  "description": "Multimedia Downloader",
  "author": "Dhruv Jangid",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "oxfmt --write .",
    "lint": "oxlint .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build": "bun run typecheck && electron-vite build",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:win": "bun run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "clean": "rm -rf node_modules bun.lock && bun clean:build",
    "clean:build": "rm -rf dist out",
    "in": "bun i && bun update && bun update -i",
    "down": "bun run scripts/download-binaries.ts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "adm-zip": "^0.5.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "next-themes": "^0.4.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "terser": "^5.47.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "7.3.1"
  }
}
