{
  "name": "desktop",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "turbo -F ui build && electrobun dev",
    "dev": "electrobun dev --watch",
    "build": "electrobun build",
    "build:stable": "electrobun build --env=stable",
    "build:canary": "electrobun build --env=canary",
    "check-types": "tsc --noEmit",
    "scripts:bin": "bun run scripts/download-binaries.ts"
  },
  "dependencies": {
    "@grabbr/contracts": "workspace:*",
    "electrobun": "catalog:"
  },
  "devDependencies": {
    "@grabbr/config": "workspace:*",
    "@grabbr/rpc": "workspace:*",
    "resedit-cli": "^3.1.0",
    "typescript": "catalog:"
  }
}
